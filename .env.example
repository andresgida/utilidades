# ============================================================
# UTILIDADES — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- PostgreSQL ----
POSTGRES_DB=utilidades_db
POSTGRES_USER=utilidades_user
POSTGRES_PASSWORD=ChangeMe_SuperSecure123!
POSTGRES_PORT=5432

# ---- Backend ----
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# ---- JWT ----
JWT__Secret=ChangeMe_AtLeast32CharactersLong!SuperSecret
JWT__Issuer=https://utilidades.app
JWT__Audience=https://utilidades.app
JWT__AccessTokenExpiryMinutes=15
JWT__RefreshTokenExpiryDays=7

# ---- Database Connection ----
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=utilidades_db;Username=utilidades_user;Password=ChangeMe_SuperSecure123!

# ---- CORS ----
AllowedOrigins=http://localhost:4200,https://utilidades.app

# ---- Rate Limiting ----
RateLimiting__PermitLimit=100
RateLimiting__WindowSeconds=60
RateLimiting__QueueLimit=10

# ---- Serilog ----
Serilog__MinimumLevel=Information

# ---- Frontend ----
ANGULAR_API_URL=http://localhost:5000/api
